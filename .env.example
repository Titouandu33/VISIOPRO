# ─── VISIOPRO — Variables d'environnement (copier en .env et remplir) ────────
# Ne JAMAIS commiter le fichier .env — ce fichier .env.example est le modèle

# ─── Serveur ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=https://votre-domaine.com,https://app.votre-domaine.com

# ─── Base de données PostgreSQL (Railway ou Supabase) ────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/visiopro

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGER_PAR_UNE_CHAINE_ALEATOIRE_LONGUE_MINIMUM_64_CARACTERES

# ─── Email (Nodemailer — SMTP) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@email.com
SMTP_PASS=VOTRE_MOT_DE_PASSE_APPLICATION
EMAIL_FROM=noreply@votre-domaine.com

# ─── Twilio (SMS invitations) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=VOTRE_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=VOTRE_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+33XXXXXXXXX

# ─── Stripe (paiements) ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=VOTRE_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=VOTRE_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_MENSUEL=VOTRE_STRIPE_PRICE_MENSUEL
STRIPE_PRICE_ANNUEL=VOTRE_STRIPE_PRICE_ANNUEL
STRIPE_PRICE_ESSAI=VOTRE_STRIPE_PRICE_ESSAI
